{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // "allowJs": true,
    // "checkJs": true,
    "jsx": "react-jsx",
    "jsxImportSource": "ags/gtk4",
    "lib": ["ES2023"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020"
  }
}
